@model List<ClubEventApp.DTO.EventSummaryViewModel>
@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container mt-4">
    <h2 class="mb-3">Sự kiện đang mở đăng ký</h2>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info">Hiện chưa có sự kiện nào được công bố.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Tên sự kiện</th>
                        <th>Địa điểm</th>
                        <th>Thời gian</th>
                        <th>Chỗ trống</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var evt in Model)
                    {
                        <tr>
                            <td>@evt.EventName</td>
                            <td>@evt.Location</td>
                            <td>@evt.StartTime:dd/MM/yyyy HH:mm - @evt.EndTime:dd/MM/yyyy HH:mm</td>
                            <td>@evt.AvailableSlots</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
