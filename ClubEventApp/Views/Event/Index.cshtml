@model List<ClubEventApp.DTO.EventSummaryViewModel>
@{
    ViewData["Title"] = "Quản lý sự kiện";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Danh sách sự kiện</h2>
        <a asp-action="Create" class="btn btn-primary">Tạo sự kiện</a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info">Chưa có sự kiện nào.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Tên sự kiện</th>
                        <th>Địa điểm</th>
                        <th>Thời gian</th>
                        <th>Trạng thái</th>
                        <th>Chỗ trống</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var evt in Model)
                    {
                        <tr>
                            <td>@evt.EventName</td>
                            <td>@evt.Location</td>
                            <td>@evt.StartTime.ToString("dd/MM/yyyy HH:mm") - @evt.EndTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@evt.Status</td>
                            <td>@evt.AvailableSlots</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
